{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "LS",
      "Edit",
      "Write",
      "Bash(dotnet build*)",
      "Bash(dotnet test*)",
      "Bash(dotnet format*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(Get-ChildItem*)",
      "Bash(Select-String*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fdx*)",
      "Bash(dotnet nuget push*)",
      "Bash(docker system prune*)",
      "Bash(*publish*)",
      "Bash(*Remove-Item -Recurse*)",
      "Bash(*rm -rf*)",
      "Read(**/.env*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)"
    ]
  }
}
